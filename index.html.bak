<script>
(function(){
  var stored = localStorage.getItem('ao-theme');
  var hour = new Date().getHours();
  var isDark = stored ? stored === 'dark' : (hour >= 20 || hour < 7);
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');

  window.addEventListener('DOMContentLoaded', function(){
    var pill = document.createElement('button');
    pill.className = 'theme-pill';
    pill.id = 'themePill';
    pill.textContent = isDark ? '☀️ Day Mode' : '🌙 Night Mode';
    pill.onclick = function(){
      var cur = document.documentElement.getAttribute('data-theme');
      var next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('ao-theme', next);
      pill.textContent = next === 'dark' ? '☀️ Day Mode' : '🌙 Night Mode';
    };
    document.body.appendChild(pill);
  });
})();
</script>
